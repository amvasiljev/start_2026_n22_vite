mixin logo(opts = {})
    - const type = opts.type || 'link'
    - const attr = opts.attr || ''
    - const tag = type === 'link' ? 'a' : 'div'
    - const href = type === 'link' ? (opts.href || '/') : null
    - const logoType = opts.logoType || 'svg'
    - const svgIcon = opts.svgIcon || 'svg_logo'
    - const imgName = opts.imgName || 'logo' // имя файла без расширения
    - const imgFolder = opts.imgFolder || 'logo' // папка с изображениями
    - const imgExt = opts.imgExt || 'png'
    - const text = opts.text || 'Название компании'
    - const ariaLabel = opts.ariaLabel || text + ' — главная страница'
    - const width = opts.width || '180'
    - const height = opts.height || '60'
    - const customAttrs = opts.attrs || {}
    
    - let baseAttrs = { 'data-app-logo': attr || '' }
    if tag === 'a'
        - baseAttrs.href = href
        - baseAttrs['aria-label'] = ariaLabel
    
    - Object.assign(baseAttrs, customAttrs)
    
    #{tag}&attributes(baseAttrs)
        case logoType
            when 'svg'
                svg(
                    width=width,
                    height=height,
                    role="img",
                    aria-labelledby="logoTitle"
                )
                    title(id="logoTitle")= text
                    use(xlink:href= img + `sprite.svg#${svgIcon}`)
            
            when 'img'
                picture
                    source(srcset=img + `${imgFolder}/avif/${imgName}.avif` type="image/avif")
                    source(srcset=img + `${imgFolder}/webp/${imgName}.webp` type="image/webp")
                    img(
                        src=img + `${imgFolder}/${imgName}.${imgExt}`,
                        alt=text,
                        width=width,
                        height=height,
                        loading="lazy",
                        decoding="async"
                    )
            
            when 'text'
                span= text



